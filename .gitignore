# =============================================================================
# liferay-release-analytics .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Credentials and config with secrets
# -----------------------------------------------------------------------------
config/config.yml

# -----------------------------------------------------------------------------
# Staging — all intermediate RDS and CSV files
# Large files, regenerated by pipeline, no source value in git
# -----------------------------------------------------------------------------
staging/

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
session-summaries.md

# -----------------------------------------------------------------------------
# Export outputs — generated by export_looker.R, not source files
# -----------------------------------------------------------------------------
reports/situation_deck/exports/
reports/release_landscape/exports/

# -----------------------------------------------------------------------------
# Dashboard rendered output
# -----------------------------------------------------------------------------
reports/situation_deck/release_situation_deck.html
dashboard/

# -----------------------------------------------------------------------------
# R session artifacts
# -----------------------------------------------------------------------------
.Rhistory
.RData
.Rproj.user/
*.Rproj

# -----------------------------------------------------------------------------
# OS artifacts
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Data files — raw churn CSVs are source data, keep them
# Uncomment below if you want to exclude them
# -----------------------------------------------------------------------------
data/

# -----------------------------------------------------------------------------
# Python environment
# -----------------------------------------------------------------------------
.venv/