# =============================================================================
# liferay-release-analytics .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Credentials and config with secrets
# -----------------------------------------------------------------------------
config/config.yml

# -----------------------------------------------------------------------------
# Staging — intermediate RDS and CSV files
# Regenerated by pipeline, no source value in git
# -----------------------------------------------------------------------------
staging/

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
session-summaries.md

# -----------------------------------------------------------------------------
# Generated outputs — CSVs, plots, rendered HTML
# Source R/Rmd scripts in these directories ARE tracked
# -----------------------------------------------------------------------------
output/
ad-hoc/output/
reports/**/*.csv
reports/**/plots/
reports/**/*.html

# -----------------------------------------------------------------------------
# R session artifacts
# -----------------------------------------------------------------------------
.Rhistory
.RData
.Rproj.user/
*.Rproj

# -----------------------------------------------------------------------------
# OS artifacts
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Data files — raw CSVs ingested from lizard/git/Jira extraction
# Source inputs, regenerated by extract scripts; too large for git
# (lizard_output alone is ~240MB, exceeds GitHub's 100MB limit)
# -----------------------------------------------------------------------------
data/*.csv

# -----------------------------------------------------------------------------
# Python environment
# -----------------------------------------------------------------------------
.venv/
__pycache__/

# -----------------------------------------------------------------------------
# Triage runtime artifacts — per-run bundles, traces, and legacy output
# prepare.py writes per-run bundles to apps/triage/runs/r_<id>/ (can be 100MB+)
# -----------------------------------------------------------------------------
apps/triage/traces/
apps/triage/output/
apps/triage/runs/