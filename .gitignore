# =============================================================================
# liferay-release-analytics .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Credentials and config with secrets
# -----------------------------------------------------------------------------
config/config.yml

# -----------------------------------------------------------------------------
# Staging — intermediate RDS and CSV files
# Regenerated by pipeline, no source value in git
# -----------------------------------------------------------------------------
staging/

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
session-summaries.md

# -----------------------------------------------------------------------------
# Generated outputs — CSVs, plots, rendered HTML
# Source R/Rmd scripts in these directories ARE tracked
# -----------------------------------------------------------------------------
output/
ad-hoc/output/
reports/**/*.csv
reports/**/plots/
reports/**/*.html

# -----------------------------------------------------------------------------
# R session artifacts
# -----------------------------------------------------------------------------
.Rhistory
.RData
.Rproj.user/
*.Rproj

# -----------------------------------------------------------------------------
# OS artifacts
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Data files — raw churn CSVs ingested from lizard/git extraction
# These are source inputs, kept in git for reproducibility
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Python environment
# -----------------------------------------------------------------------------
.venv/
__pycache__/

# -----------------------------------------------------------------------------
# Triage runtime artifacts — per-run traces and batch output, not source
# -----------------------------------------------------------------------------
apps/triage/traces/
apps/triage/output/